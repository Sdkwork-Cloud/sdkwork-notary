{
  "name": "sdkwork-notary-workspace",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@sdkwork/app-topology": "file:../sdkwork-app-topology"
  },
  "scripts": {
    "dev": "node scripts/notary-dev.mjs --deployment-profile standalone",
    "dev:cloud": "node scripts/notary-dev.mjs --deployment-profile cloud",
    "dev:browser:postgres:unified-process:standalone": "pnpm --dir apps/sdkwork-notary-h5 dev",
    "dev:browser": "pnpm dev:browser:postgres:unified-process:standalone",
    "dev:desktop:postgres:unified-process:standalone": "pnpm --dir apps/sdkwork-notary-pc dev",
    "dev:desktop": "pnpm dev:desktop:postgres:unified-process:standalone",
    "build:browser": "pnpm --dir apps/sdkwork-notary-h5 build",
    "build:desktop": "pnpm --dir apps/sdkwork-notary-pc build",
    "test:browser": "pnpm --dir apps/sdkwork-notary-h5 test",
    "test:desktop": "pnpm --dir apps/sdkwork-notary-pc test",
    "build": "cargo build --workspace",
    "typecheck": "pnpm --dir apps/sdkwork-notary-h5 typecheck && pnpm --dir apps/sdkwork-notary-pc typecheck",
    "check": "pnpm test:topology-validate && pnpm db:validate && pnpm format:check && pnpm typecheck && node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --application-code-prefix notary",
    "clean": "cargo clean --target-dir target-codex-test",
    "test": "pnpm.cmd test:contracts",
    "test:contracts": "node --test sdks/test/*.test.mjs scripts/dev/*.test.mjs scripts/verify-notary-standard-architecture.test.mjs scripts/verify-notary-iam-manifest.test.mjs scripts/verify-notary-utils-standard.test.mjs apps/sdkwork-notary-h5/src/__tests__/*.test.mjs apps/sdkwork-notary-pc/src/__tests__/*.test.mjs tests/contract/*.test.mjs",
    "test:topology-baggage": "node --test scripts/dev/sdkwork-notary-topology-baggage.test.mjs",
    "test:topology-validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:validate": "pnpm test:topology-validate",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "test:rust": "cargo test --workspace --target-dir target-codex-test",
    "api:materialize": "node scripts/sync-notary-openapi-authorities.mjs && node scripts/generate-notary-route-manifests.mjs && node scripts/sync-notary-api-framework-metadata.mjs",
    "api:materialize:check": "node --test sdks/test/notary-web-framework.test.mjs",
    "api:check": "pnpm api:materialize:check && node --test sdks/test/notary-contracts.test.mjs",
    "sdk:generate:app": "node sdks/sdkwork-notary-app-sdk/bin/generate-sdk.mjs",
    "sdk:generate:backend": "node sdks/sdkwork-notary-backend-sdk/bin/generate-sdk.mjs",
    "sdk:generate": "pnpm sdk:generate:app && pnpm sdk:generate:backend",
    "sdk:generate:check": "node --test tests/contract/sdk-generate-check.contract.test.mjs",
    "sdk:check": "pnpm sdk:generate:check && node --test sdks/test/notary-composed-facade.test.mjs sdks/test/notary-frontend-adapter.test.mjs",
    "api:envelope:check": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .",
    "verify": "pnpm.cmd check && pnpm.cmd test:topology-baggage && pnpm.cmd api:check && pnpm.cmd api:envelope:check && pnpm.cmd sdk:check && pnpm.cmd gateway:assembly:validate && pnpm.cmd test:contracts && pnpm.cmd test:rust && pnpm.cmd build:browser && pnpm.cmd build:desktop",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_notary_foundation.sql --module-id notary --owner notary-platform --prefixes notary_ --engines postgres",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "format:check": "cargo fmt -p sdkwork-notary-case-contract -p sdkwork-notary-case-service -p sdkwork-notary-case-repository-sqlx -p sdkwork-notary-database-host -p sdkwork-notary-embedded-bootstrap -p sdkwork-notary-gateway-assembly -p sdkwork-routes-notary-http-auth -p sdkwork-routes-notary-app-api -p sdkwork-routes-notary-backend-api -- --check",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "gateway:package:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs bundle --root .",
    "gateway:validate:cloud": "node ../sdkwork-app-topology/scripts/gateway-cloud-bundle.mjs validate --root .",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs"
  }
}
