{
  "name": "sdkwork-notary-workspace",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@sdkwork/app-topology": "file:../sdkwork-app-topology"
  },
  "scripts": {
    "test": "pnpm.cmd test:contracts",
    "test:contracts": "node --test sdks/test/*.test.mjs scripts/dev/*.test.mjs scripts/verify-notary-standard-architecture.test.mjs",
    "test:topology-baggage": "node --test scripts/dev/sdkwork-notary-topology-baggage.test.mjs",
    "test:topology-validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "test:rust": "cargo test --workspace --target-dir target-codex-test",
    "notary:dev": "node scripts/notary-dev.mjs --hosting self-hosted",
    "notary:dev:cloud": "node scripts/notary-dev.mjs --hosting cloud-hosted",
    "sdk:generate:app": "node sdks/sdkwork-notary-app-sdk/bin/generate-sdk.mjs",
    "sdk:generate:backend": "node sdks/sdkwork-notary-backend-sdk/bin/generate-sdk.mjs",
    "sdk:generate": "pnpm sdk:generate:app && pnpm sdk:generate:backend",
    "openapi:materialize": "node scripts/sync-notary-openapi-authorities.mjs && node scripts/sync-notary-api-framework-metadata.mjs",
    "manifest:generate": "node scripts/generate-notary-route-manifests.mjs",
    "manifest:sync": "node scripts/generate-notary-route-manifests.mjs && node scripts/sync-notary-api-framework-metadata.mjs",
    "verify": "pnpm.cmd test:topology-validate && pnpm.cmd test:topology-baggage && pnpm.cmd test:contracts && cargo fmt --all --check && pnpm.cmd test:rust"
  }
}
