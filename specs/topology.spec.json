{
  "schemaVersion": 2,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-notary",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{serviceLayout}.{environment}.env",
  "vocabulary": {
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    },
    "serviceLayout": {
      "allowed": [
        "split-services"
      ]
    },
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    },
    "connectivityPlane": {
      "allowed": [
        "application",
        "platform"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.split-services.development",
    "productionProfileId": "cloud.split-services.production",
    "gatewayBind": "127.0.0.1:3900"
  },
  "profileFiles": {
    "standalone.split-services.development": "configs/topology/standalone.split-services.development.env",
    "cloud.split-services.development": "configs/topology/cloud.split-services.development.env",
    "standalone.split-services.production": "configs/topology/standalone.split-services.production.env",
    "cloud.split-services.production": "configs/topology/cloud.split-services.production.env"
  },
  "envKeys": {
    "deploymentProfile": "SDKWORK_NOTARY_DEPLOYMENT_PROFILE",
    "serviceLayout": "SDKWORK_NOTARY_SERVICE_LAYOUT",
    "environment": "SDKWORK_NOTARY_ENVIRONMENT",
    "profileId": "SDKWORK_NOTARY_PROFILE_ID",
    "clientDeploymentProfile": "VITE_SDKWORK_NOTARY_DEPLOYMENT_PROFILE",
    "gatewayAutostart": "SDKWORK_NOTARY_PLATFORM_API_GATEWAY_AUTOSTART",
    "cloudGatewayBind": "SDKWORK_API_CLOUD_GATEWAY_BIND",
    "apiGatewayBaseUrl": "SDKWORK_NOTARY_PLATFORM_API_GATEWAY_HTTP_URL",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_NOTARY_PLATFORM_API_GATEWAY_HTTP_URL"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_NOTARY_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_NOTARY_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_NOTARY_APPLICATION_PUBLIC_HTTP_URL"
    },
    "application.backend-http": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_NOTARY_APPLICATION_BACKEND_HTTP_BIND",
      "httpUrlEnv": "SDKWORK_NOTARY_APPLICATION_BACKEND_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_NOTARY_APPLICATION_BACKEND_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "owner": "sdkwork-api-cloud-gateway",
      "bindEnv": "SDKWORK_API_CLOUD_GATEWAY_BIND",
      "httpUrlEnv": "SDKWORK_NOTARY_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_NOTARY_PLATFORM_API_GATEWAY_HTTP_URL",
      "autostartEnv": "SDKWORK_NOTARY_PLATFORM_API_GATEWAY_AUTOSTART"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "notary.sdkwork.com"
    },
    "application.backend-http": {
      "httpHost": "notary-admin.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_NOTARY"
  },
  "components": {
    "appApiRouter": {
      "crate": "sdkwork-routes-notary-app-api",
      "library": "sdkwork_routes_notary_app_api"
    },
    "backendApiRouter": {
      "crate": "sdkwork-routes-notary-backend-api",
      "library": "sdkwork_routes_notary_backend_api"
    },
    "cloudGateway": {
      "crate": "sdkwork-api-cloud-gateway-api-server",
      "binary": "sdkwork-api-cloud-gateway",
      "repository": "sdkwork-api-cloud-gateway"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.split-services.development": {
        "processes": [],
        "healthSurfaces": [
          "application.public-ingress",
          "application.backend-http",
          "platform.api-gateway"
        ]
      },
      "cloud.split-services.development": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway-api-server",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": false
          }
        ],
        "healthSurfaces": [
          "platform.api-gateway"
        ]
      },
      "cloud.split-services.production": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway-api-server",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": false
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "application.backend-http",
          "platform.api-gateway"
        ]
      }
    }
  },
  "scripts": {
    "notaryDev": "scripts/notary-dev.mjs"
  },
  "retired": {
    "envKeys": [
      "SDKWORK_NOTARY_TOPOLOGY",
      "VITE_SDKWORK_NOTARY_TOPOLOGY",
      "SDKWORK_NOTARY_HOSTING",
      "VITE_SDKWORK_NOTARY_HOSTING"
    ],
    "profileIds": [
      "self-hosted.split-services.development",
      "cloud-hosted.split-services.development",
      "self-hosted.split-services.production",
      "cloud-hosted.split-services.production"
    ],
    "notes": "sdkwork-notary is a domain library. Host applications wire sdkwork-routes-notary-* route crates and load profile env from this repository."
  },
  "packaging": {
    "cloudConfigFiles": [
      "sdkwork-api-cloud-gateway.notary.development.toml",
      "sdkwork-api-cloud-gateway.notary.production.toml"
    ],
    "targets": [
      {
        "id": "container-noarch-cloud-container-config-bundle-tar-gz",
        "profile": "container",
        "platform": "container",
        "architecture": "noarch",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-notary-api-gateway-config-*.tar.gz",
        "deploymentProfile": "cloud",
        "runtimeTarget": "container",
        "variant": "config-bundle"
      }
    ]
  }
}
