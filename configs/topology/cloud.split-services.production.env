# Notary topology profile: cloud + split-services + production

SDKWORK_NOTARY_DEPLOYMENT_PROFILE=cloud
SDKWORK_NOTARY_SERVICE_LAYOUT=split-services
SDKWORK_NOTARY_ENVIRONMENT=production
SDKWORK_NOTARY_PROFILE_ID=cloud.split-services.production

SDKWORK_NOTARY_APPLICATION_PUBLIC_HTTP_URL=https://notary.sdkwork.com
SDKWORK_NOTARY_APPLICATION_BACKEND_HTTP_URL=https://notary-admin.sdkwork.com

SDKWORK_API_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_NOTARY_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_NOTARY_PLATFORM_API_GATEWAY_AUTOSTART=true

VITE_SDKWORK_NOTARY_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_NOTARY_APPLICATION_PUBLIC_HTTP_URL=https://notary.sdkwork.com
VITE_SDKWORK_NOTARY_APPLICATION_BACKEND_HTTP_URL=https://notary-admin.sdkwork.com
VITE_SDKWORK_NOTARY_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com

# Inject from secret manager at deploy time; required for PII field encryption in production.
# NOTARY_PII_VAULT_KEY=
