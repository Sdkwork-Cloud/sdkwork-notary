# Notary topology profile: cloud + split-services + development

SDKWORK_NOTARY_DEPLOYMENT_PROFILE=cloud
SDKWORK_NOTARY_SERVICE_LAYOUT=split-services
SDKWORK_NOTARY_ENVIRONMENT=development
SDKWORK_NOTARY_PROFILE_ID=cloud.split-services.development

SDKWORK_NOTARY_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:3900
SDKWORK_NOTARY_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:3900

SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_NOTARY_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_NOTARY_PLATFORM_API_GATEWAY_AUTOSTART=true

VITE_SDKWORK_NOTARY_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_NOTARY_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_NOTARY_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:3900
VITE_SDKWORK_NOTARY_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.notary.development.toml
