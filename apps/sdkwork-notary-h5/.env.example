# SDKWork private bootstrap credential (blank in tracked files).
# Resolved tokens belong in .env.<mode>.bootstrap.local only.

SDKWORK_ACCESS_TOKEN=

# Public browser runtime config (non-secret).
VITE_SDKWORK_NOTARY_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:18085
VITE_SDKWORK_NOTARY_APPLICATION_BACKEND_HTTP_URL=http://127.0.0.1:18086
VITE_SDKWORK_NOTARY_DEPLOYMENT_PROFILE=standalone
